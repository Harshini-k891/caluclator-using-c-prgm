#include<stdio.h>
int calci_menu(int a, int b, int choice)
{
    if(choice == 1)
        return a + b;
    else if(choice == 2)
        return a - b;
    else if(choice == 3)
        return a * b;
    else if(choice == 4)
        return a / b;
    else
        printf("Invalid choice\n");
        return 0;
}
int main()
{
    int m, n, choice, result;

    printf("Enter two numbers: ");
    scanf("%d%d", &m, &n);

    printf("\nChoose operation:\n");
    printf("1. Addition\n");
    printf("2. Subtraction\n");
    printf("3. Multiplication\n");
    printf("4. Division\n");
    printf("Enter choice: ");
    scanf("%d", &choice);
    result = calci_menu(m, n, choice);
    printf("Result = %d\n", result);
    return 0;
}
